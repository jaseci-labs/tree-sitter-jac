{
  "name": "tree-sitter-jac",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Jac programming language",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaseci-labs/tree-sitter-jac.git"
  },
  "keywords": [
    "tree-sitter",
    "parser",
    "jac",
    "jaclang",
    "jaseci"
  ],
  "scripts": {
    "build-grammar": "jac run grammar.jac",
    "generate": "tree-sitter generate src/grammar.json",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse",
    "corpus": "bash scripts/corpus-check.sh"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.6"
  },
  "tree-sitter": [
    {
      "scope": "source.jac",
      "file-types": [
        "jac"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "injections": "queries/injections.scm"
    }
  ]
}
