{
  "name": "tree-sitter-jac",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Jac programming language",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaseci-labs/tree-sitter-jac.git"
  },
  "keywords": [
    "tree-sitter",
    "parser",
    "jac",
    "jaclang",
    "jaseci"
  ],
  "main": "bindings/node",
  "types": "bindings/node",
  "scripts": {
    "generate": "tree-sitter generate",
    "build": "tree-sitter generate && node-gyp build",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse",
    "corpus": "node scripts/corpus-check.js",
    "install": "node-gyp-build",
    "prebuildify": "prebuildify --napi --strip"
  },
  "files": [
    "grammar.js",
    "binding.gyp",
    "queries/*",
    "src/**",
    "bindings/**"
  ],
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp-build": "^4.8.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.6",
    "prebuildify": "^6.0.0"
  },
  "tree-sitter": [
    {
      "scope": "source.jac",
      "file-types": [
        "jac"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "injections": "queries/injections.scm"
    }
  ]
}
