{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "jac",
      "camelcase": "Jac",
      "scope": "source.jac",
      "path": ".",
      "file-types": [
        "jac"
      ],
      "highlights": [
        "queries/jac/highlights.scm"
      ],
      "injections": [
        "queries/jac/injections.scm"
      ],
      "locals": [
        "queries/jac/locals.scm"
      ],
      "injection-regex": "^jac$",
      "first-line-regex": "^#!.*\\bjac\\b"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Jac programming language, authored in Jac using object-spatial programming.",
    "authors": [
      {
        "name": "Jason Mars",
        "email": "jason@mars.ninja"
      }
    ],
    "links": {
      "repository": "https://github.com/jaseci-labs/tree-sitter-jac",
      "homepage": "https://www.jac-lang.org"
    },
    "namespace": "jaseci-labs"
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
